# RigbSecurity Tracker — Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 8000)
PORT=8000

# Dashboard authentication password (auto-generated if not set)
DASHBOARD_PASSWORD=

# Telegram notifications: BOT_TOKEN:CHAT_ID (e.g. 123456:AABBcc:987654)
TELEGRAM=

# Discord/Custom webhook URL for notifications
WEBHOOK=

# VAPID keys for Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC=
VAPID_PRIVATE=
